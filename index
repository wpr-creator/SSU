<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --navy:      #0a1628;
  --navy-mid:  #1a2e50;
  --red:       #b22234;
  --red-light: #cc3344;
  --white:     #f8f6f0;
  --off-white: #ede8df;
  --gold:      #c8a84b;
  --text:      #1a1a1a;
  --text-muted:#5a5a6a;
  --rule:      rgba(184,34,52,0.25);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Source Sans 3', sans-serif;
  background: var(--white);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── HERO HEADER ── */
.hero {
  position: relative;
  width: 100%;
  min-height: 480px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
}

.hero-img {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to bottom, rgba(10,22,40,0.35) 0%, rgba(10,22,40,0.72) 100%),
    url('images/header_US.jpg') center center / cover no-repeat;
  background-color: var(--navy);
}

/* Animated stripe overlay — subtle flag rhythm */
.hero-stripes {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.stripe {
  position: absolute;
  left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent 0%, rgba(200,168,75,0.18) 40%, rgba(200,168,75,0.18) 60%, transparent 100%);
  animation: stripeDrift linear infinite;
}
.stripe:nth-child(1) { top: 20%; animation-duration: 18s; animation-delay: 0s; }
.stripe:nth-child(2) { top: 38%; animation-duration: 24s; animation-delay: 3s; }
.stripe:nth-child(3) { top: 56%; animation-duration: 20s; animation-delay: 7s; }
.stripe:nth-child(4) { top: 74%; animation-duration: 22s; animation-delay: 2s; }

@keyframes stripeDrift {
  0%   { opacity: 0; transform: translateX(-100%); }
  10%  { opacity: 1; }
  90%  { opacity: 1; }
  100% { opacity: 0; transform: translateX(100%); }
}

/* Floating particles */
.particles { position: absolute; inset: 0; pointer-events: none; }
.particle {
  position: absolute;
  width: 2px; height: 2px;
  border-radius: 50%;
  background: rgba(200,168,75,0.6);
  animation: particleFloat ease-in-out infinite;
}
@keyframes particleFloat {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.4; }
  50%       { transform: translateY(-20px) scale(1.5); opacity: 0.9; }
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 0 0 3.5rem;
  text-align: center;
}

.course-eyebrow {
  font-size: 0.72rem;
  letter-spacing: 0.45em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1rem;
  font-weight: 600;
}

.hero h1 {
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: clamp(3rem, 7vw, 5.5rem);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  line-height: 1.0;
  margin-bottom: 1rem;
  text-shadow: 0 2px 20px rgba(0,0,0,0.5);
}

.hero h1 span { color: var(--gold); }

.hero-rule {
  width: 60px;
  height: 2px;
  background: linear-gradient(90deg, var(--red), var(--gold));
  margin: 1.2rem auto;
  border: none;
}

.hero-sub {
  font-size: 1rem;
  color: rgba(255,255,255,0.72);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 300;
}

/* Red bottom bar on hero */
.hero-bar {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 6px;
  background: linear-gradient(90deg, var(--navy) 0%, var(--red) 35%, var(--white) 50%, var(--red) 65%, var(--navy) 100%);
}

/* ── MAIN CONTENT ── */
.page-wrap {
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 2rem 5rem;
}

/* ── SEMESTER BLOCK ── */
.semester-block { margin-top: 4rem; }

.semester-hdr {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  margin-bottom: 0.35rem;
}

.semester-title {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--navy);
  white-space: nowrap;
}

.semester-rule {
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, var(--red) 0%, rgba(184,34,52,0.1) 100%);
}

.semester-sub {
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--text-muted);
  margin-bottom: 2rem;
  padding-left: 2px;
}

/* ── CARDS ── */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 1.25rem;
}

.day-card {
  display: block;
  text-decoration: none;
  color: inherit;
  background: #ffffff;
  border: 1px solid rgba(10,22,40,0.1);
  border-top: 3px solid var(--navy);
  padding: 1.5rem 1.4rem 1.3rem;
  position: relative;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-top-color 0.2s ease;
  overflow: hidden;
}

.day-card::after {
  content: '→';
  position: absolute;
  bottom: 1.1rem;
  right: 1.2rem;
  font-size: 1rem;
  color: var(--red);
  opacity: 0;
  transform: translateX(-6px);
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.day-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 30px rgba(10,22,40,0.12);
  border-top-color: var(--red);
}

.day-card:hover::after {
  opacity: 1;
  transform: translateX(0);
}

.day-num {
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 0.7rem;
}

.card-title {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--navy);
  line-height: 1.35;
  margin-bottom: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

.card-eq {
  font-size: 0.87rem;
  color: var(--text-muted);
  font-style: italic;
  line-height: 1.55;
}

.card-std {
  margin-top: 1rem;
  padding-top: 0.8rem;
  border-top: 1px solid rgba(10,22,40,0.07);
  font-size: 0.68rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--navy);
  font-weight: 600;
  opacity: 0.55;
}

/* ── SEMESTER DIVIDER ── */
.semester-divider {
  border: none;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(184,34,52,0.2), transparent);
  margin: 1rem 0 0;
}

/* ── FOOTER ── */
footer {
  border-top: 2px solid var(--navy);
  margin-top: 4rem;
  padding: 1.5rem 0;
  text-align: center;
  font-size: 0.72rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--text-muted);
}

/* ── FADE IN ON LOAD ── */
.fade-in {
  opacity: 0;
  transform: translateY(12px);
  animation: fadeUp 0.5s ease forwards;
}
.cards-grid .fade-in:nth-child(1) { animation-delay: 0.03s; }
.cards-grid .fade-in:nth-child(2) { animation-delay: 0.07s; }
.cards-grid .fade-in:nth-child(3) { animation-delay: 0.11s; }
.cards-grid .fade-in:nth-child(4) { animation-delay: 0.15s; }
.cards-grid .fade-in:nth-child(5) { animation-delay: 0.19s; }
.cards-grid .fade-in:nth-child(6) { animation-delay: 0.23s; }
.cards-grid .fade-in:nth-child(7) { animation-delay: 0.27s; }
.cards-grid .fade-in:nth-child(8) { animation-delay: 0.31s; }

@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

@media (max-width: 640px) {
  .hero h1 { font-size: 2.4rem; }
  .cards-grid { grid-template-columns: 1fr 1fr; }
  .page-wrap { padding: 0 1rem 3rem; }
}
@media (max-width: 420px) {
  .cards-grid { grid-template-columns: 1fr; }
}
</style>
</head>
